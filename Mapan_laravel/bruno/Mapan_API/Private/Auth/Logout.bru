meta {
  name: Logout
  type: http
  seq: 4
}

post {
  url: {{private_url}}/logout
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

tests {
  test("Status is 200", function() {
    expect(res.status).to.equal(200);
  });
}

script:post-response {
  bru.setEnvVar("token", "");
}