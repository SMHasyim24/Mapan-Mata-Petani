meta {
  name: Get All Users (Super Admin)
  type: http
  seq: 1
}

get {
  url: {{base_url}}/admin/users
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("Status is 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Response is array", function() {
    expect(res.body).to.be.an('array');
  });
}

docs {
  Requires Super Admin role
}
