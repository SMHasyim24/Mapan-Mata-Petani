meta {
  name: Get All Diseases (Admin)
  type: http
  seq: 2
}

get {
  url: {{base_url}}/admin/diseases
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

tests {
  test("Status is 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Response has diseases", function() {
    expect(res.body.diseases).to.be.an('array');
  });
}

docs {
  Requires Admin or Super Admin role
}