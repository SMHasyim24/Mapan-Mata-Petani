  Future<void> createDetection({
    required String token,
    required int diseaseId,
    required String notes,
    required int diseaseId,
    required String notes,
    String method = 'image',
    double? confidence,
    List<String>? images,
    bool isReport = false,
    double? latitude,
    double? longitude,
    String? status,
  }) async {
    if (images != null && images.isNotEmpty) {
      final request = http.MultipartRequest(
        'POST',
        Uri.parse('$_baseUrl/private/api/v1/detections'),
      );
      request.headers['Authorization'] = 'Bearer $token';
      request.headers['Accept'] = 'application/json';
      request.headers['X-App-Secret'] = 'MapanRahasia2026';

      request.fields['disease_id'] = diseaseId.toString();
      request.fields['notes'] = notes;
      request.fields['method'] = method;
      request.fields['is_report'] = isReport ? '1' : '0';
      if (status != null) {
        request.fields['status'] = status;
      }
      if (confidence != null) {
        request.fields['confidence'] = confidence.toString();
      }
      if (latitude != null && longitude != null) {
        request.fields['latitude'] = latitude.toString();
        request.fields['longitude'] = longitude.toString();
      }

      List<String> finalImages = [];
      for (int i = 0; i < images.length; i++) {
        final ext = images[i].split('.').last.toLowerCase();
        final isJpgOrPng = ext == 'jpg' || ext == 'jpeg' || ext == 'png';
        if (isJpgOrPng) {
          try {
            final tempDir = await getTemporaryDirectory();
            final targetPath =
                '${tempDir.path}/comp_${DateTime.now().millisecondsSinceEpoch}_$i.jpg';
            final compressedFile =
                await FlutterImageCompress.compressAndGetFile(
                  images[i],
                  targetPath,
                  quality: 60,
                  minWidth: 1080,
                  minHeight: 1080,
                );
            } else {
              finalImages.add(images[i]);
            }
          } catch (e) {
            finalImages.add(images[i]);
          }
        } else {
          finalImages.add(images[i]);
        }
        }),
      );

      if (response.statusCode != 201) {
        throw Exception('Failed to create detection: ${response.statusCode}');
      }
    }
  }

  Future<void> reviewReport({
    required String token,
    required String detectionId,
    required String status,
    String? expertNotes,
    int? diseaseId,
    double? confidence,
  }) async {
    final response = await http.put(
      Uri.parse('$_baseUrl/private/api/v1/detections/$detectionId/review'),
      headers: {
        'Authorization': 'Bearer $token',
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-App-Secret': 'MapanRahasia2026',
      },
      body: jsonEncode({
        'status': status,
        if (expertNotes != null) 'expert_notes': expertNotes,
        if (diseaseId != null) 'disease_id': diseaseId,
        if (confidence != null) 'confidence': confidence,
      }),
    );

    if (response.statusCode != 200) {
      throw Exception('Failed to review report: ${response.statusCode}');
    }
  }

  Future<void> deleteDetection({required String token, required int id}) async {
    await request('DELETE', '/private/api/v1/detections/$id', token: token);
  }

  Future<void> claimDetection({
    required String token,
    required String id,
  }) async {
    final response = await http.post(
      Uri.parse('$_baseUrl/private/api/v1/detections/$id/claim'),
      headers: {
        'Authorization': 'Bearer $token',
        'Accept': 'application/json',
        'X-App-Secret': 'MapanRahasia2026',
      },
    );
    if (response.statusCode < 200 || response.statusCode >= 300) {
      final json = jsonDecode(response.body);
      throw Exception(
        json['message'] ?? 'Gagal mengambil laporan: ${response.statusCode}',
      );
    }
  }

  Future<List<dynamic>> fetchMapStatistics(String token) async {
    final response = await request(
      'GET',
      '/private/api/v1/admin/map-statistics',
      token: token,
    );
    return response['data'] as List<dynamic>? ?? [];
  }

  Future<void> unclaimDetection({
    required String token,
    required String id,
  }) async {
    final response = await http.post(
      Uri.parse('$_baseUrl/private/api/v1/detections/$id/unclaim'),
      headers: {
        'Authorization': 'Bearer $token',
        'Accept': 'application/json',
        'X-App-Secret': 'MapanRahasia2026',
      },
    );
    if (response.statusCode < 200 || response.statusCode >= 300) {
      final json = jsonDecode(response.body);
      throw Exception(
        json['message'] ?? 'Gagal membatalkan laporan: ${response.statusCode}',
      );
    }
  }








































































































































































































